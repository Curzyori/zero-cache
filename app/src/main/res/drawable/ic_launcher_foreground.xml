<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ZeroCache Mark: Stylized "0" with cache sweep arrow -->
    <!-- Outer ring (the zero) -->
    <path
        android:pathData="M54,30
                          m-22,0
                          a22,22 0 1,0 44,0
                          a22,22 0 1,0 -44,0
                          M54,30
                          m-14,0
                          a14,14 0 1,1 28,0
                          a14,14 0 1,1 -28,0"
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd" />

    <!-- Center "0" indicator (smaller dot, the cleared state) -->
    <path
        android:pathData="M54,30 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0"
        android:fillColor="#5645D4" />

    <!-- Sweep arrow on the right side of the ring (cache clearing motion) -->
    <path
        android:pathData="M76,30 L82,30 M79,27 L82,30 L79,33"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Bottom progress bar (cache size indicator) -->
    <path
        android:pathData="M30,68 L78,68"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Progress fill (75% filled, showing cache accumulating) -->
    <path
        android:pathData="M30,68 L68,68"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Progress node at end (the "current cache" point) -->
    <path
        android:pathData="M68,68 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0"
        android:fillColor="#FFFFFF" />

</vector>
